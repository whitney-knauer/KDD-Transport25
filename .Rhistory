#HUGE Variation!!!!
#sex
fit <- survfit(
surv_obj ~ SEX,
data = full)
ggsurvplot(
fit,
data = full,
pval = TRUE,
pval.coord = c(5, 0.6),
conf.int = TRUE,
risk.table = FALSE,
xlab = "Time (days)",
ylab = "Sepsis Treatment Survival Probability",
xlim = c(0, 30),
ylim = c(0.5, 1.0),
legend = "top",
break.time.by = 7)
