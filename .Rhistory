#| warning: false
summary(EXCLUDE$SD)
#letting the data decide
EXCLUDE<- EXCLUDE %>%
mutate(quartile = cut(SD,
breaks = quantile(SD, probs = seq(0, 1, 0.25), na.rm = TRUE, names = FALSE) %>% unique(),
include.lowest = TRUE))
EXCLUDE %>%
count(quartile) %>%
mutate(pct = n / sum(n) * 100)
#creating categores myself
EXCLUDE <- EXCLUDE %>%
mutate(quart_custom = case_when(
SD <= 3.5 ~ "High",
SD > 3.5 & SD <= 3.75 ~ "Med",
SD > 3.75 & SD <= 4 ~ "Medlow",
SD > 4 ~ "Low",
TRUE ~ "Other"))
EXCLUDE %>%
count(quart_custom) %>%
mutate(pct = n / sum(n) * 100)
EXCLUDE %>%
group_by (quartile) %>%
summarize(
mean = mean(SD))
EXCLUDE %>%
group_by (as.factor(comp), quartile) %>%
summarize(
mean = mean(SD))
#problem with compartment 4, there is no "low" category. I think that's the jail, so they put fewer calves in there in general.
EXCLUDE %>%
group_by (quart_custom) %>%
summarize(
mean = mean(SD))
EXCLUDE %>%
group_by (as.factor (comp), quart_custom) %>%
summarize(
mean = mean(SD))
#same problem, but only 2 of the quartiles with compartment 4 data.
