# Load necessary libraries
library(ggplot2)
library(tidyr)
library(dplyr)
# 1. Create the dataset
# Based on the table provided:
# Columns 1-2 are Milk (6h, 18h), Columns 3-4 are Electrolytes (6h, 18h)
data <- data.frame(
Marker = c("Glucose (mmol/L)", "Urea (mmol/L)", "NEFA (µmol/L)", "Total protein (g/L)", "Osmolality (mosmol/kg)"),
Milk_6h = c(4.71, 5.51, 586.5, 66.90, 310.6),
Milk_18h = c(3.10, 5.40, 853.2, 59.62, 297.5),
Electrolytes_6h = c(3.56, 5.64, 916.0, 59.81, 300.6),
Electrolytes_18h = c(3.35, 7.38, 837.7, 64.77, 312.0)
)
# 2. Transform data to 'long' format for plotting
data_long <- data %>%
pivot_longer(
cols = -Marker,
names_to = c("Feeding", "Transport_Time"),
names_sep = "_",
values_to = "Value"
)
# 3. Create the bar graph
ggplot(data_long, aes(x = Transport_Time, y = Value, fill = Feeding)) +
geom_bar(stat = "identity", position = position_dodge(width = 0.9)) +
facet_wrap(~ Marker, scales = "free_y") + # Separate plots for each marker
theme_minimal() +
labs(
title = "Comparison of Transport Time vs. Feeding Type",
x = "Transport Duration",
y = "Measured Value",
fill = "Feeding Group"
) +
scale_fill_brewer(palette = "Set1") +
theme(strip.text = element_text(face = "bold", size = 10))
# Load necessary libraries
library(ggplot2)
library(tidyr)
library(dplyr)
# 1. Create the dataset with only Glucose and NEFA
data <- data.frame(
Marker = c("Glucose (mmol/L)", "NEFA (µmol/L)"),
Milk_6h = c(4.71, 586.5),
Milk_18h = c(3.10, 853.2),
Electrolytes_6h = c(3.56, 916.0),
Electrolytes_18h = c(3.35, 837.7)
)
# 2. Transform data to 'long' format
data_long <- data %>%
pivot_longer(
cols = -Marker,
names_to = c("Feeding", "Transport_Time"),
names_sep = "_",
values_to = "Value"
)
# 3. Explicitly set the order of Transport_Time (6h on left, 18h on right)
data_long$Transport_Time <- factor(data_long$Transport_Time, levels = c("6h", "18h"))
# 4. Create the bar graph
ggplot(data_long, aes(x = Transport_Time, y = Value, fill = Feeding)) +
geom_bar(stat = "identity", position = position_dodge(width = 0.8), width = 0.7) +
facet_wrap(~ Marker, scales = "free_y") +
theme_classic() +
labs(
title = "Metabolic Response: Transport Duration vs. Feeding Type",
x = "Transport Duration",
y = "Concentration",
fill = "Feeding Group"
) +
scale_fill_manual(values = c("Electrolytes" = "#377eb8", "Milk" = "#e41a1c")) +
theme(
strip.text = element_text(face = "bold", size = 12),
axis.title = element_text(face = "bold"),
legend.position = "top"
)
# Load necessary libraries
library(ggplot2)
library(tidyr)
library(dplyr)
# 1. Create the dataset including the SEM (Standard Error of Mean) from your table
data <- data.frame(
Marker = c("Glucose (mmol/L)", "NEFA (µmol/L)"),
Milk_6h = c(4.71, 586.5),
Milk_18h = c(3.10, 853.2),
Electrolytes_6h = c(3.56, 916.0),
Electrolytes_18h = c(3.35, 837.7),
SEM = c(0.14, 54.8) # SEM values from your table
)
# 2. Transform data to 'long' format
data_long <- data %>%
pivot_longer(
cols = c(Milk_6h, Milk_18h, Electrolytes_6h, Electrolytes_18h),
names_to = c("Feeding", "Transport_Time"),
names_sep = "_",
values_to = "Value"
)
# 3. Ensure 6h is on the left and 18h is on the right
data_long$Transport_Time <- factor(data_long$Transport_Time, levels = c("6h", "18h"))
# 4. Create the stacked bar graph
ggplot(data_long, aes(x = Transport_Time, y = Value, fill = Feeding)) +
# Bars are "dodged" (side-by-side) for direct comparison within each time point
geom_bar(stat = "identity", position = position_dodge(0.8), width = 0.7) +
# Adding the Standard Error (SE) bars
geom_errorbar(
aes(ymin = Value - SEM, ymax = Value + SEM),
position = position_dodge(0.8),
width = 0.2
) +
# facet_wrap with ncol = 1 stacks the Glucose and NEFA plots on top of each other
facet_wrap(~ Marker, ncol = 1, scales = "free_y") +
theme_classic() +
labs(
title = "Metabolic Response: Glucose and NEFA",
subtitle = "Comparing Feeding Type and Transport Duration",
x = "Transport Duration",
y = "Concentration (Mean ± SEM)",
fill = "Feeding Group"
) +
scale_fill_manual(values = c("Electrolytes" = "#377eb8", "Milk" = "#e41a1c")) +
theme(
strip.text = element_text(face = "bold", size = 12),
axis.title = element_text(face = "bold"),
legend.position = "top",
panel.grid.major.y = element_line(color = "grey90") # Adds light lines for readability
)
# Load necessary libraries
library(ggplot2)
library(tidyr)
library(dplyr)
# 1. Create the dataset
data <- data.frame(
Marker = c("Glucose (mmol/L)", "NEFA (µmol/L)"),
Milk_6h = c(4.71, 586.5),
Milk_18h = c(3.10, 853.2),
Electrolytes_6h = c(3.56, 916.0),
Electrolytes_18h = c(3.35, 837.7),
SEM = c(0.14, 54.8)
)
# 2. Transform data to 'long' format
data_long <- data %>%
pivot_longer(
cols = c(Milk_6h, Milk_18h, Electrolytes_6h, Electrolytes_18h),
names_to = c("Feeding", "Transport_Time"),
names_sep = "_",
values_to = "Value"
)
# 3. Ensure 6h is on the left and 18h is on the right
data_long$Transport_Time <- factor(data_long$Transport_Time, levels = c("6h", "18h"))
# 4. Create the unstacked (side-by-side) bar graph
ggplot(data_long, aes(x = Transport_Time, y = Value, fill = Feeding)) +
geom_bar(stat = "identity", position = position_dodge(0.7), width = 0.6) +
geom_errorbar(
aes(ymin = Value - SEM, ymax = Value + SEM),
position = position_dodge(0.7),
width = 0.15
) +
# nrow = 1 puts Glucose and NEFA side-by-side
facet_wrap(~ Marker, nrow = 1, scales = "free_y") +
theme_classic() +
labs(
title = "Metabolic Response Comparison",
x = "Transport Duration",
y = "Mean Value ± SEM",
fill = "Feeding Group"
) +
# Using a clean color palette
scale_fill_manual(values = c("Electrolytes" = "#5DADE2", "Milk" = "#E74C3C")) +
theme(
strip.background = element_rect(fill = "grey95", color = NA),
strip.text = element_text(face = "bold", size = 11),
axis.line = element_line(color = "black"),
legend.position = "bottom"
)
