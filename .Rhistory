NAVAL30 = coalesce(dfaN1, 30),
NAV30 = if_else(dfaN1 < 30, 1L, 0L, missing = 0L),
ILLMISC30 = coalesce(dfaIM1, 30),
IM30 = if_else(dfaIM1 <30, 1L, 0L, missing = 0L),
INJURY10 = coalesce(dfaI1, 10),
I10 = if_else(dfaI1<10, 1L, 0L, missing = 0L),
LAME10 = coalesce(dfaL1, 10),
L10 = if_else(dfaL1<10, 1L, 0L, missing = 0L),
SEPSIS30 = coalesce(dfaS1, 30),
S30 = if_else(dfaS1<30, 1L, 0L, missing = 0L),
DIED30 = coalesce(dfaDIED, 30),
DED30 = if_else(dfaDIED<30, 1L, 0L, missing = 0L),
DIED60 = coalesce(dfaDIED, 60),
DED60 = if_else(dfaDIED<60, 1L, 0L, missing = 0L))
EXCLUDE %>%
