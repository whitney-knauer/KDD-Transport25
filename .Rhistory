library(epiDisplay)
library(knitr)
library(pROC)
library(tidyverse)
library(readxl)
library(ggplot2)
library(gmodels)
library(ggbeeswarm)
library(dplyr)
library(readr)
library(ggpubr)
library(psych)
library(lme4)
library(Matrix)
library(lmerTest)
library(irr)
library(lmerTest)
library(emmeans)
library(doBy)
library(gmodels)
library(car)
library(cowplot)
library(gridGraphics)
library(multcomp)
library(hms)
library(gt)
library(lubridate)
library(nlme)
library(extrafont)
sheeps <- read_excel("data/TPI Data.xlsx", sheet = "Farm 1 - Sheep")
goats <- read_excel("data/TPI Data.xlsx", sheet = "Farm 2 - Goats")
calf1 <- read_excel("data/TPI Data.xlsx", sheet = "Farm 3 - Dairy + Beef")
calf2 <- read_excel("data/TPI Data.xlsx", sheet = "Farm 4 - Calf Depot")
sheeps |>
ggplot(mapping=aes(STP))+
theme_classic()+
geom_histogram(binwidth=0.5,
fill="purple3",
color="black",
alpha=0.7)+
labs(title = "Histogram of STP - SHEEP")
#create categories
sheeps<-sheeps %>%
mutate(levels =
case_when (
STP <=5.1 ~ "LOW",
STP > 5.1 ~ "ADEQUATE"))
sheeps %>%
group_by(levels) %>%
count()
goats |>
ggplot(mapping=aes(STP))+
theme_classic()+
geom_histogram(binwidth=0.5,
fill="pink",
color="black",
alpha=0.7)+
labs(title = "Histogram of STP - GOATS")
#create categories
goats<-goats %>%
mutate(levels =
case_when (
STP <=5.1 ~ "LOW",
STP > 5.1 ~ "ADEQUATE"))
goats %>%
group_by(levels) %>%
count()
calf1 |>
ggplot(mapping=aes(STP))+
theme_classic()+
geom_histogram(binwidth=0.5,
fill="red4",
color="black",
alpha=0.7)+
labs(title = "Histogram of STP - Calf1")
#create categories
calf1<-calf1 %>%
mutate(levels =
case_when (
STP < 5.1               ~ "Poor",
STP >= 5.1 & STP <= 5.7 ~ "Fair",
STP >= 5.8 & STP <= 6.1 ~ "Good",
STP >= 6.2              ~ "Excellent"))
calf1$levels <- factor(calf1$levels,
levels = c("Excellent", "Good", "Fair", "Poor"))
calf1 %>%
group_by(levels) %>%
count()
calf1 %>%
group_by (sex, levels) %>%
count()
calf1 %>%
group_by (Breed, levels) %>%
count()
# Create a small reference for your goals
goal_data <- tibble(
levels = c("Excellent", "Good", "Fair", "Poor"),
goal = c("> 25%", "40%", "20%", "< 15%") # Replace with your actual goals
)
# Build the summary dataframe
table_data <- calf1 %>%
group_by(levels) %>%
summarize(n = n(), .groups = "drop") %>%
mutate(proportion = n / sum(n)) %>%
left_join(goal_data, by = "levels")
table_data %>%
gt() %>%
cols_align(
align = "center",
columns = everything()) %>%
# Add a Header
tab_header(
title = "STP Level Distribution") %>%
# Format the proportion column as a clean percentage
fmt_percent(
columns = proportion,
decimals = 1
) %>%
# Rename columns for the display
cols_label(
levels = "Category",
n = "Count",
proportion = "Actual %",
goal = "Target Goal") %>%
# Add some nice styling
opt_stylize(color = "red", style = 1) %>%
tab_options(
table.width = pct(80),
column_labels.font.weight = "bold")
# Create a small reference for your goals
goal_data <- tibble(
levels = c("Excellent", "Good", "Fair", "Poor"),
goal = c("> 25%", "40%", "20%", "< 15%") # Replace with your actual goals
)
# Build the summary dataframe
table_data <- calf1 %>%
group_by(Breed, levels) %>%
summarize(n = n(), .groups = "drop_last") %>%
mutate(proportion = n / sum(n)) %>%
left_join(goal_data, by = "levels")
table_data %>%
gt() %>%
cols_align(
