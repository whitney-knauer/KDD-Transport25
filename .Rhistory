full <- read.csv('data/FULL.csv')
full$comp = as.factor(full$comp)
full$SRCE = as.factor(full$SRCE)
full$comp <- relevel(as.factor(full$comp), ref = "2")
dia30_model <- coxme(Surv(DIAR30, D30) ~ comp*quart_custom  + SRCE + CBRD + diaARR + (1|month/LOADfull),
data = full)
full$comp <- relevel(as.factor(full$comp), ref = "2")
dia30_model <- coxme(Surv(DIAR30, D30) ~ comp*quart_custom  + SRCE + CBRD + (1|month/LOADfull),
data = full)
full$comp <- relevel(as.factor(full$comp), ref = "2")
dia30_model <- coxme(Surv(DIAR30, D30) ~ comp*quart_custom + (1|month/LOADfull),
data = full)
full$comp <- relevel(as.factor(full$comp), ref = "2")
dia30_model <- coxme(Surv(DIAR30, D30) ~ comp + (1|month/LOADfull),
data = full)
full$comp <- relevel(as.factor(full$comp), ref = "2")
dia30_model <- coxme(Surv(DIAR30, D30) ~ comp + (1|month/LOADfull),
data = full)
summary(dia30_model)
Anova(dia30_model, type = "III")
test_ph <- cox.zph(dia30_model)
print(test_ph)
plot(test_ph)
# Plot it (Flat line = assumption holds)
interaction_means <- emmeans(dia30_model, ~comp)
sd_contrasts <- pairs(interaction_means, reverse = FALSE)
summary(sd_contrasts, type = "response", infer = c(TRUE, TRUE))
full$comp <- relevel(as.factor(full$comp), ref = "2")
dia30_model <- coxme(Surv(DIAR30, D30) ~ comp + quart_custom + SEX + SRCE + (1|month/LOADfull),
data = full)
summary(dia30_model)
full$comp <- relevel(as.factor(full$comp), ref = "2")
dia30_model <- coxme(Surv(DIAR30, D30) ~ comp + quart_custom + SEX + (1|SRCE) + (1|month/LOADfull),
data = full)
full$comp <- relevel(as.factor(full$comp), ref = "2")
dia30_model <- coxme(Surv(DIAR30, D30) ~ quart_custom + (1|SRCE) + (1|month/LOADfull),
data = full)
