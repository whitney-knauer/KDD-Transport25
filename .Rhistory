surv_obj <- Surv(
time  = full$DIAR30,
event = full$D30)
#by compartment
fit <- survfit(
surv_obj ~ comp,
data = full)
ggsurvplot(
fit,
data = full,
pval = TRUE,
pval.coord = c(5, 0.6),
conf.int = TRUE,
risk.table = FALSE,
xlab = "Time (days)",
ylab = "Scours Treatment Survival Probability",
xlim = c(0, 28),
ylim = c(0.5, 1.0),
legend = "top",
break.time.by = 7)
table(full$D30)
#by stocking density quartile
fit <- survfit(
surv_obj ~ quart_custom,
data = full)
ggsurvplot(
fit,
data = full,
pval = TRUE,
pval.coord = c(5, 0.6),
conf.int = TRUE,
risk.table = FALSE,
xlab = "Time (days)",
ylab = "Scours Treatment Survival Probability",
xlim = c(0, 28),
ylim = c(0.5, 1.0),
legend = "top",
break.time.by = 7)
#month
fit <- survfit(
surv_obj ~ month,
data = full)
ggsurvplot(
fit,
data = full,
pval = TRUE,
pval.coord = c(5, 0.6),
conf.int = TRUE,
risk.table = FALSE,
xlab = "Time (days)",
ylab = "Scours Treatment Survival Probability",
xlim = c(0, 28),
ylim = c(0.5, 1.0),
legend = "top",
break.time.by = 7)
#by distinct load
fit <- survfit(
