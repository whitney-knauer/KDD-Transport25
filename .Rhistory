library(epiDisplay)
library(knitr)
library(pROC)
library(tidyverse)
library(readxl)
library(ggplot2)
library(gmodels)
library(ggbeeswarm)
library(dplyr)
library(readr)
library(ggpubr)
library(psych)
library(lme4)
library(Matrix)
library(lmerTest)
library(irr)
library(lmerTest)
library(emmeans)
library(doBy)
library(gmodels)
library(car)
library(cowplot)
library(gridGraphics)
library(multcomp)
library(hms)
library(gt)
library(lubridate)
library(nlme)
library(extrafont)
#pull in data
kdd1 <- read_csv('data/kdd1.csv')
kdd2 <- read_csv('data/kdd2.csv')
kdd3 <- read_csv('data/kdd3.csv')
kdd4 <- read_csv('data/kdd4.csv')
kdd5 <- read_csv('data/kdd5.csv')
#trim all data so it can be merged
kdd1trim <-
kdd1 %>%
select( "ID", "EID", "CBRD", "BDAT", "Event", "DIM", "Date", "Remark")
kdd2trim <-
kdd2 %>%
select( "ID", "EID", "CBRD", "BDAT", "Event", "DIM", "Date", "Remark")
kdd3trim <-
kdd3 %>%
select( "ID", "EID", "CBRD", "BDAT", "Event", "DIM", "Date", "Remark")
kdd4trim <-
kdd4 %>%
select( "ID", "EID", "CBRD", "BDAT", "Event", "DIM", "Date", "Remark")
kdd5trim <-
kdd5 %>%
select( "ID", "EID", "CBRD", "BDAT", "Event", "DIM", "Date", "Remark")
#merge into one data set
STACK <-
bind_rows(
kdd1trim = kdd1trim,
kdd2trim = kdd2trim,
kdd3trim = kdd3trim,
kdd4trim = kdd4trim,
kdd5trim = kdd5trim,
.id = "source"
)
STACK %>%
group_by(Event, Remark) %>%
count()
#pull out events we want
stack_new <-
STACK %>%
filter(Event %in% c("PNEU", "GODEER", "Remark", "SCOURS", "DIED", "DIM", "MEASURE", "ARVDPOT", "ARVKDD", "BLOAT", "HLTHSCR", "ILLMISC", "INJURY", "LAME", "NAVEL", "OTITIS", "SEPTIC"))
stack_new1 <- stack_new %>%
mutate(Date = lubridate::mdy(Date)) %>%
arrange(ID, Event, Date) %>%   # ensure chronological order
group_by(ID, Event, Date) %>%
slice_head(n = 3) %>%
ungroup()
stack_new2 <-
stack_new1 %>%
group_by(ID, Event) %>%
mutate(Event_num = row_number()) %>%
ungroup() %>%
unite(Event_tag, Event, Event_num, sep="")
stack_new3<-
stack_new2 %>%
pivot_wider(
id_cols = c(ID, CBRD),
names_from = Event_tag,
values_from = c(Date, Remark, DIM) )
#get rid of calves that don't have a godeer event
stack_new3 <- stack_new3 %>%
filter(!is.na(Date_GODEER1))
final<-
stack_new3 %>%
select(
ID, CBRD, Date_PNEU1, Remark_PNEU1, Date_PNEU2, Remark_PNEU2, Date_PNEU3, Remark_PNEU3, Date_SCOURS1, Remark_SCOURS1, Date_SCOURS2, Remark_SCOURS2, Date_MEASURE1, Remark_MEASURE1, Date_MEASURE2, Remark_MEASURE2, Date_DIED1, Remark_DIED1, Date_GODEER1, Remark_GODEER1, Date_ARVKDD1, Remark_ARVKDD1, Date_ARVDPOT1, Date_BLOAT1, Remark_BLOAT1, Date_BLOAT2, Remark_BLOAT2, Date_HLTHSCR1, Remark_HLTHSCR1, Date_ILLMISC1, Remark_ILLMISC1, Date_INJURY1, Remark_INJURY1, Date_INJURY2, Remark_INJURY2, Date_LAME1, Remark_LAME1, Date_NAVEL1, Remark_NAVEL1, Date_OTITIS1, Remark_OTITIS1, Date_SEPTIC1, Remark_SEPTIC1)
final %>%
group_by(Remark_GODEER1) %>%
count()
enroll <- read_csv('data/KDD enroll.csv')
final$ID <- as.character(final$ID)
enroll$ID <- as.character(enroll$ID)
full <- final %>%
left_join(enroll, by = "ID")
full <- full %>%
filter(Date_GODEER1 < "2025-11-13") %>%
relocate(EID, BDAT, SEX, CBRD.y, TPROT, BTHWT, .before = ID) %>%
select(-CBRD.x, -GODER, -BTHWT)
full <- full %>%
filter(!is.na(as.numeric(TPROT))) %>%
mutate(TPROT = as.numeric(TPROT))
write.csv(x = full, file = "data/FINAL.csv")
full %>%
group_by(Remark_GODEER1) %>%
count()
full_dates<-full %>%
mutate(
wt1 = as.numeric(Remark_MEASURE1),
wt2 = as.numeric (Remark_MEASURE2))
full_dates <- full_dates %>%
mutate(
LOAD = factor(paste(Date_GODEER1, Remark_GODEER1, sep = "_")))
full_dates <- full_dates %>%
mutate(
LOADfull = factor(paste(Date_GODEER1)))
datachecks <- full_dates %>%
count(LOAD)
datachecks1 <- full_dates %>%
count(LOADfull)
datachecks
datachecks1
write.csv(x = datachecks, file = "data/trailer loads comp.csv")
write.csv(x=datachecks1, file = "data/trailer load.csv")
write.csv(x=full_dates, file = "data/checks.csv")
#any comp with NA or <10 calves were removed as this seemed unlikely (n = 7 compartments totaling n=41 calves was removed )
comp <- read_csv('data/COMPARTMENTS.csv') %>%
drop_na()
head(comp$SD)
comp %>%
summarize(
total = sum(n))
comp %>%
group_by(comp) %>%
summarize(
total = sum(n),
calves = mean(n),
calvessd = sd(n))
comp %>%
group_by(comp) %>%
summarize(
total = sum(n),
Stockingrate =mean(SD),
sd = sd(SD))
comp %>%
group_by(date) %>%
summarize(
total = sum(n),
sd = mean(SD))
comp %>%
ggplot(aes(x=as.factor(comp), y=n, color = as.factor(comp)))+
geom_boxplot()+
geom_jitter() +
theme_classic()
comp %>%
ggplot(aes(x=as.factor(comp), y=SD, color = as.factor(comp)))+
geom_boxplot()+
geom_jitter() +
theme_classic()
#need to merge compartments and full data set together so each calf has that data.
full_comp <- full_dates %>%
inner_join(comp, by = "LOAD")
#inner join goes from 41965 to 41661
full_new <- full_comp %>%
mutate(across(c(BDAT, starts_with("Date_")),
~ as.Date(parse_date_time(trimws(as.character(.x)), orders = c("mdy", "dmy", "ymd"))))) %>%
mutate(
diaload = as.numeric(Date_GODEER1 - BDAT),
diaARR  = as.numeric(Date_ARVKDD1 - BDAT),
dfaP1   = as.numeric(Date_PNEU1 - Date_ARVKDD1),
dbtwP12 = as.numeric(Date_PNEU2 - Date_PNEU1),
dbtwP23 = as.numeric(Date_PNEU3 - Date_PNEU2),
dfaP2   = as.numeric(Date_PNEU2 - Date_ARVKDD1),
dfaP3   = as.numeric(Date_PNEU3 - Date_ARVKDD1),
dfaD1   = as.numeric(Date_SCOURS1 - Date_ARVKDD1),
dfaD2   = as.numeric(Date_SCOURS2 - Date_ARVKDD1),
dbtwD12 = as.numeric(Date_SCOURS2 - Date_SCOURS1),
dfaB1   = as.numeric(Date_BLOAT1 - Date_ARVKDD1),
dfaB2   = as.numeric(Date_BLOAT2 - Date_ARVKDD1),
dfaN1   = as.numeric(Date_NAVEL1 - Date_ARVKDD1),
dfaIM1  = as.numeric(Date_ILLMISC1 - Date_ARVKDD1),
dfaI1   = as.numeric(Date_INJURY1 - Date_ARVKDD1),
dfaL1   = as.numeric(Date_LAME1 - Date_ARVKDD1),
dfaO1   = as.numeric(Date_OTITIS1 - Date_ARVKDD1),
dfaS1   = as.numeric(Date_SEPTIC1 - Date_ARVKDD1),
dfaDIED = as.numeric(Date_DIED1 - Date_ARVKDD1))
full_new <- full_new %>%
mutate(BDAT = if_else(diaload < 0, Date_ARVDPOT1, BDAT)) %>%
mutate( diaload = as.numeric(Date_GODEER1 - BDAT),
diaARR  = as.numeric(Date_ARVKDD1 - BDAT),
diaW1   = as.numeric(Date_MEASURE1 - BDAT),
diaW2   = as.numeric(Date_MEASURE2 - BDAT))
#weights are still fucked up. Have to fix dates and/or shift birth to wean when appropriate. Or just ommit all the calves who don't have full data.
write.csv(x=full_new, file = "data/datachecks.csv")
#now need to define dia1, pneu1, etc and tag animals who were treated prior to transport.
full_new1<- full_new %>%
mutate(
PN1a = if_else(dfaP1>=0, 1, 0) %>% replace_na(0),
PN2 = if_else(dfaP2>=0, 1, 0)%>% replace_na(0),
PN3 = if_else(dfaP3>=0, 1, 0) %>% replace_na(0),
DIA1 = ifelse(dfaD1>=0, 1, 0)%>% replace_na(0),
DIA2 = ifelse(dfaD2>=0, 1, 0)%>% replace_na(0),
B1 = ifelse(dfaB1>=0, 1, 0)%>% replace_na(0),
B2 = ifelse(dfaB2>=0, 1, 0)%>% replace_na(0),
N1 = ifelse(dfaN1>=0, 1, 0) %>% replace_na(0),
IM1 = ifelse(dfaIM1>=0, 1, 0) %>% replace_na(0),
I1 = ifelse(dfaI1 >=0, 1, 0) %>% replace_na(0),
L1 = ifelse(dfaL1 >=0, 1, 0) %>% replace_na(0),
O1 = ifelse(dfaO1>=0, 1, 0) %>% replace_na(0),
Sep1 = ifelse(dfaS1>=0, 1, 0) %>% replace_na(0),
DIED = ifelse(dfaDIED>=0, 1, 0)%>% replace_na(0))
full_new1 <- full_new1 %>%
mutate(
RESPex =
case_when(is.na(dfaP1) ~ 0,
dfaP1<0 ~  1,
dfaP1>= 0 ~ 0))
full_new1 <- full_new1 %>%
mutate(
DIAex =
case_when(is.na(dfaD1) ~ 0,
dfaD1<0 ~  1,
dfaD1>= 0 ~ 0))
full_new1 <- full_new1 %>%
mutate(
navelex =
case_when(is.na(dfaN1) ~ 0,
dfaN1<0 ~  1,
dfaN1>= 0 ~ 0))
full_new1 <- full_new1 %>%
mutate(
bloatex =
case_when(is.na(dfaB1) ~ 0,
dfaB1<0 ~  1,
dfaB1>= 0 ~ 0))
full_new1 <- full_new1 %>%
mutate(
illex =
case_when(is.na(dfaIM1) ~ 0,
dfaIM1<0 ~  1,
dfaIM1>= 0 ~ 0))
full_new1 <- full_new1 %>%
mutate(
injuryex =
case_when(is.na(dfaI1) ~ 0,
dfaI1<0 ~  1,
dfaI1>= 0 ~ 0))
full_new1 <- full_new1 %>%
mutate(
lameex =
case_when(is.na(dfaL1) ~ 0,
dfaL1<0 ~  1,
dfaL1>= 0 ~ 0))
full_new1 <- full_new1 %>%
mutate(
septicex =
case_when(is.na(dfaS1) ~ 0,
dfaS1<0 ~  1,
dfaS1>= 0 ~ 0))
full_new1 <- full_new1 %>%
mutate(
diedex =
case_when(is.na(dfaDIED) ~ 0,
dfaDIED<0 ~  1,
dfaDIED>= 0 ~ 0))
full_new1 %>%
count(RESPex, DIAex, navelex, bloatex, illex, injuryex, lameex, septicex, diedex)
full_new1 <- full_new1 %>%
mutate(trtb4 =
case_when(
RESPex == 1 | DIAex == 1 | navelex == 1 | bloatex == 1 | illex == 1 | injuryex == 1 | lameex == 1 | septicex ==1     ~  1,
RESPex == 0 | DIAex == 0 | navelex == 0 | bloatex == 0 | illex == 0 | injuryex == 0 | lameex == 0 | septicex == 0    ~ 0))
full_new1 %>%
count(trtb4)
#remove the calf that was recorded to have died two days before it was born?
full_new1 <- full_new1 %>%
filter(diedex == 0)
notrt_before <- full_new1 %>%
filter(!if_any(c(RESPex, DIAex, navelex, bloatex, illex, injuryex, lameex, septicex, diedex), ~ . == 1))
#look at some other things to mess with prior to making final data sets:
full_new1 |>
ggplot(mapping=aes(TPROT))+
theme_classic()+
geom_histogram(binwidth=0.2,
fill="skyblue",
color="black",
alpha=0.7)+
labs(title = "Histogram of stp")
full_new1|>
ggplot(mapping=aes(x=diaARR))+
theme_classic()+
geom_histogram(binwidth=1,
fill="orange",
color="black",
alpha=0.7)+
labs(title = "Histogram of days in age at arrival")
full_new1|>
ggplot(mapping=aes(x=wt1))+
theme_classic()+
geom_histogram(binwidth=0.2,
fill="purple",
color="black",
alpha=0.7)+
labs(title = "Histogram of Depot weight")
full_new1|>
ggplot(mapping=aes(x=wt2))+
theme_classic()+
geom_histogram(binwidth=0.2,
fill="pink",
color="black",
alpha=0.7)+
labs(title = "Histogram of wean weight")
FULL <- full_new1 %>%
select (ID, BDAT, SEX, CBRD.y, TPROT, wt1, wt2, LOADfull, comp, SD, diaload, diaARR, trtb4, DIA1, dfaD1, DIAex, Remark_SCOURS1, PN1a, dfaP1, RESPex, Remark_PNEU1, B1, dfaB1, Remark_BLOAT1, bloatex,  N1, dfaN1, Remark_NAVEL1, navelex, IM1, dfaIM1, Remark_ILLMISC1, illex, I1, dfaI1, Remark_INJURY1, injuryex, L1, dfaL1, Remark_LAME1, lameex, Sep1, dfaS1, Remark_SEPTIC1, septicex, DIED, dfaDIED, Remark_DIED1, diedex)
EXCLUDE <- notrt_before %>%
select(ID, BDAT, SEX, CBRD.y, TPROT, wt1, wt2, LOADfull, comp, SD, diaload, diaARR, DIA1, dfaD1, Remark_SCOURS1, PN1a, dfaP1, Remark_PNEU1, B1, dfaB1, Remark_BLOAT1, N1, dfaN1, Remark_NAVEL1, IM1, dfaIM1, Remark_ILLMISC1, I1, dfaI1, Remark_INJURY1, L1, dfaL1, Remark_LAME1, Sep1, dfaS1, Remark_SEPTIC1, DIED, dfaDIED, Remark_DIED1)
write.csv(x=FULL, file = 'data/FULL.csv')
write.csv(x=EXCLUDE, file = 'data/EXCLUDE.csv')
full_dates<-full %>%
mutate(
wt1 = as.numeric(Remark_MEASURE1),
wt2 = as.numeric (Remark_MEASURE2))
full_dates <- full_dates %>%
mutate(
LOAD = factor(paste(Date_GODEER1, Remark_GODEER1, sep = "_")))
full_dates <- full_dates %>%
mutate(
LOADfull = factor(paste(Date_GODEER1)))
datachecks <- full_dates %>%
count(LOAD)
datachecks1 <- full_dates %>%
count(LOADfull)
datachecks
datachecks1
write.csv(x = datachecks, file = "data/trailer loads comp.csv")
write.csv(x=datachecks1, file = "data/trailer load.csv")
write.csv(x=full_dates, file = "data/checks.csv")
