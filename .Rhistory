stack_new <-
STACK %>%
filter(Event %in% c("PNEU", "GODEER", "Remark", "SCOURS", "DIED"))
stack_new <-
STACK %>%
filter(Event %in% c("PNEU", "GODEER", "Remark", "SCOURS", "DIED", "DIM", "MEASURE"))
stack_new1 <- stack_new %>%
arrange(ID, Event, Date) %>%   # ensure chronological order
group_by(ID, Event) %>%
slice_head(n = 3) %>%
ungroup()
stack_new2 <-
stack_new1 %>%
group_by(ID, Event) %>%
mutate(Event_num = row_number()) %>%
ungroup() %>%
unite(Event_tag, Event, Event_num, sep="")
stack_new3<-
stack_new2 %>%
pivot_wider(
id_cols = c(ID, CBRD),
names_from = Event_tag,
values_from = c(Date, Remark)
)
View(stack_new3)
View(stack_new3)
