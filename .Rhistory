full$comp <- relevel(as.factor(full$comp), ref = "2")
dia30_model <- coxme(Surv(DIAR30, D30) ~ comp + SEX + (1|LOADfull) + (1|month) + (1|SRCE),  data = full)
summary(dia30_model)
Anova(dia30_model, type = "III")
test_ph <- cox.zph(dia30_model)
print(test_ph)
plot(test_ph)
# Plot it (Flat line = assumption holds)
interaction_means <- emmeans(dia30_model, ~ comp)
sd_contrasts <- pairs(interaction_means, reverse = FALSE)
summary(sd_contrasts, type = "response", infer = c(TRUE, TRUE))
full$quart_custom <- relevel(as.factor(full$quart_custom), ref = "High")
dia30_model <- coxme(Surv(DIAR30, D30) ~ quart_custom + SEX + (1|LOADfull) + (1|month) + (1|SRCE),  data = full)
summary(dia30_model)
Anova(dia30_model, type = "III")
test_ph <- cox.zph(dia30_model)
print(test_ph)
plot(test_ph)
# Plot it (Flat line = assumption holds)
interaction_means <- emmeans(dia30_model, ~ quart_custom)
sd_contrasts <- pairs(interaction_means, reverse = FALSE)
summary(sd_contrasts, type = "response", infer = c(TRUE, TRUE))
