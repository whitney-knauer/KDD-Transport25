geom_histogram()
#300ish calves treated for "LAME" in the first day or week of arrival. What is going on there, injury?
EXCLUDE|>
ggplot(mapping=aes(x=dfaS1))+
theme_classic()+
geom_histogram()
#septic calves all in the first 40d.
EXCLUDE|>
ggplot(mapping=aes(x=dfaDIED))+
theme_classic()+
geom_histogram()
#majority in the first 100d.
EXCLUDE %>%
summarize(across(c(DIA1, PN1a, B1, N1, IM1, I1, L1, Sep1, DIED), sum, na.rm=TRUE ))
disease <- EXCLUDE %>%
count(DIA1, PN1a, B1, N1, IM1, I1, L1, Sep1, DIED)
EXCLUDE %>%
count(Remark_SCOURS1, Remark_PNEU1, Remark_BLOAT1, Remark_NAVEL1, Remark_ILLMISC1, Remark_INJURY1, Remark_LAME1, Remark_SEPTIC1, Remark_DIED1)
write.csv(x=disease, file = 'data/disease.csv')
#want to do this again after getting rid of stuff that happened later (after 60d)
EXCLUDE %>%
count(DIA1, missing_age = is.na(dfaD1))
EXCLUDE %>%
count(PN1a, missing_age = is.na(dfaP1))
EXCLUDE %>%
count(B1, missing_age = is.na(dfaB1))
EXCLUDE <- EXCLUDE %>%
mutate(
# Diarrhea
DIAR30    = pmin(coalesce(dfaD1, 30), 30),
D30       = if_else(dfaD1 < 30, 1L, 0L, missing = 0L),
# Pneumonia
PNEU30    = pmin(coalesce(dfaP1, 30), 30),
P30       = if_else(dfaP1 < 30, 1L, 0L, missing = 0L),
PNEU60    = pmin(coalesce(dfaP1, 60), 60),
P60       = if_else(dfaP1 < 60, 1L, 0L, missing = 0L),
# Bloat
BLOAT30   = pmin(coalesce(dfaB1, 30), 30),
B30       = if_else(dfaB1 < 30, 1L, 0L, missing = 0L),
# Naval
NAVAL30   = pmin(coalesce(dfaN1, 30), 30),
NAV30     = if_else(dfaN1 < 30, 1L, 0L, missing = 0L),
# Misc Illness
ILLMISC30 = pmin(coalesce(dfaIM1, 30), 30),
IM30      = if_else(dfaIM1 < 30, 1L, 0L, missing = 0L),
# Injury & Lame (10-day window)
INJURY10  = pmin(coalesce(dfaI1, 10), 10),
I10       = if_else(dfaI1 < 10, 1L, 0L, missing = 0L),
LAME10    = pmin(coalesce(dfaL1, 10), 10),
L10       = if_else(dfaL1 < 10, 1L, 0L, missing = 0L),
# Sepsis
SEPSIS30  = pmin(coalesce(dfaS1, 30), 30),
S30       = if_else(dfaS1 < 30, 1L, 0L, missing = 0L),
# Mortality
DIED30    = pmin(coalesce(dfaDIED, 30), 30),
DED30     = if_else(dfaDIED < 30, 1L, 0L, missing = 0L),
DIED60    = pmin(coalesce(dfaDIED, 60), 60),
DED60     = if_else(dfaDIED < 60, 1L, 0L, missing = 0L))
EXCLUDE %>%
summarize(across(c(D30, P30, P60, B30, NAV30, IM30, I10, L10, S30, DED30, DED60), sum, na.rm=TRUE ))
