select(ID, BDAT, SEX, CBRD.y, TPROT, wt1, wt2, LOADfull, comp, SD, diaload, diaARR, DIA1, dfaD1, Remark_SCOURS1, PN1a, dfaP1, Remark_PNEU1, B1, dfaB1, Remark_BLOAT1, N1, dfaN1, Remark_NAVEL1, IM1, dfaIM1, Remark_ILLMISC1, I1, dfaI1, Remark_INJURY1, L1, dfaL1, Remark_LAME1, Sep1, dfaS1, Remark_SEPTIC1, DIED, dfaDIED, Remark_DIED1)
write.csv(x=FULL, file = 'data/FULL.csv')
write.csv(x=EXCLUDE, file = 'data/EXCLUDE.csv')
#need to merge compartments and full data set together so each calf has that data.
full_comp <- full_dates %>%
inner_join(comp, by = "LOAD")
#inner join goes from 41965 to 41661
full_new <- full_comp %>%
mutate(across(c(BDAT, starts_with("Date_")),
~ as.Date(parse_date_time(trimws(as.character(.x)), orders = c("mdy", "dmy", "ymd"))))) %>%
mutate(
diaload = as.numeric(Date_GODEER1 - BDAT),
diaARR  = as.numeric(Date_ARVKDD1 - BDAT),
dfaP1   = as.numeric(Date_PNEU1 - Date_ARVKDD1),
dbtwP12 = as.numeric(Date_PNEU2 - Date_PNEU1),
dbtwP23 = as.numeric(Date_PNEU3 - Date_PNEU2),
dfaP2   = as.numeric(Date_PNEU2 - Date_ARVKDD1),
dfaP3   = as.numeric(Date_PNEU3 - Date_ARVKDD1),
dfaD1   = as.numeric(Date_SCOURS1 - Date_ARVKDD1),
dfaD2   = as.numeric(Date_SCOURS2 - Date_ARVKDD1),
dbtwD12 = as.numeric(Date_SCOURS2 - Date_SCOURS1),
dfaB1   = as.numeric(Date_BLOAT1 - Date_ARVKDD1),
dfaB2   = as.numeric(Date_BLOAT2 - Date_ARVKDD1),
dfaN1   = as.numeric(Date_NAVEL1 - Date_ARVKDD1),
dfaIM1  = as.numeric(Date_ILLMISC1 - Date_ARVKDD1),
dfaI1   = as.numeric(Date_INJURY1 - Date_ARVKDD1),
dfaL1   = as.numeric(Date_LAME1 - Date_ARVKDD1),
dfaO1   = as.numeric(Date_OTITIS1 - Date_ARVKDD1),
dfaS1   = as.numeric(Date_SEPTIC1 - Date_ARVKDD1),
dfaDIED = as.numeric(Date_DIED1 - Date_ARVKDD1))
full_new <- full_new %>%
mutate(BDAT = if_else(diaload < 0, Date_ARVDPOT1, BDAT)) %>%
mutate( diaload = as.numeric(Date_GODEER1 - BDAT),
diaARR  = as.numeric(Date_ARVKDD1 - BDAT),
diaW1   = as.numeric(Date_MEASURE1 - BDAT),
diaW2   = as.numeric(Date_MEASURE2 - BDAT))
write.csv(x=full_new, file = "data/datachecks.csv")
