### Add Stuff, manipulate dates

```{r}


full_dates <- full %>%
  mutate(
    BDAT = mdy(BDAT),
    Date_PNEU1 = mdy(Date_PNEU1), 
    Date_PNEU2 = mdy(Date_PNEU2), 
    Date_PNEU3 = mdy(Date_PNEU3), 
    Date_SCOURS1 = mdy(Date_SCOURS1), 
    Date_SCOURS2 = mdy(Date_SCOURS2), 
    Date_MEASURE1 = mdy(Date_MEASURE1), 
    Date_MEASURE2 = mdy(Date_MEASURE2), 
    Date_DIED1 = mdy(Date_DIED1), 
    Date_GODEER1 = mdy(Date_GODEER1))


full_dates<-full_dates %>% 
  mutate(
    wt1 = as.numeric(Remark_MEASURE1), 
    wt2 = as.numeric (Remark_MEASURE2))


full_dates <- full_dates %>%
  mutate(
    LOAD = factor(paste(Date_GODEER1, Remark_GODEER1, sep = "_")))

full_dates <- full_dates %>%
  mutate(
    LOADfull = factor(paste(Date_GODEER1)))

datachecks <- full_dates %>% 
  count(LOAD) 

datachecks1 <- full_dates %>% 
  count(LOADfull)

datachecks
datachecks1

write.csv(x = datachecks, file = "data/trailer loads comp.csv")
write.csv(x=datachecks1, file = "data/trailer load.csv")


```

