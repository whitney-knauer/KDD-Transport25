```{r}

heavy |> 
  group_by(HL) |> 
  summarize(
    mean = mean(bwtkg, na.rm=TRUE),
    sd = sd(bwtkg, na.rm=TRUE)
  )

heavy |> 
  group_by(HL) |> 
  summarize(
    mean = mean(pwadg, na.rm=TRUE),
    median = median(pwadg, na.rm=TRUE),
    sd = sd(pwadg, na.rm=TRUE)
  )


t.test(bwtkg ~ HL, data = heavy)

t.test(pwadg ~ HL, data=heavy)


heavy |> 
  ggplot(mapping = aes(x = HL, y = pwadg))+ 
  theme_classic()+
  geom_boxplot()+
  geom_line(aes(group = Pair), linetype = 2, size = 0.15) +
  geom_jitter(aes(color = study), width = 0.2, size = 2)+
  labs(y = "Pre-weaning ADG (kg)", 
       x = NULL, 
       title = NULL)


lm_hl <- lm(pwadg ~ HL*study, data=heavy)
summary(lm_hl)
plot(lm_hl)
car::Anova(lm_hl, type=3)


emmeans (lm_hl, ~ HL)
emmeans(lm_hl, ~HL:study)

x<- emmeans (lm_hl, ~HL:study)
pairwise_comparisons2 <- pairs(x)
summary(pairwise_comparisons2)





emm_df <- as.data.frame(emmeans(lm_hl, ~ HL:study))

# Plot using ggplot
ggplot(emm_df, aes(x = HL, y = emmean, color = study, group = study)) +
  geom_point(position = position_dodge(0.3), size = 3) +
  geom_errorbar(aes(ymin = emmean - SE, ymax = emmean + SE), 
                position = position_dodge(0.3), width = 0.2) +
  labs(y = "Estimated Marginal Mean", title = "Estimated Means by HL and Study") +
  theme_classic()



```
