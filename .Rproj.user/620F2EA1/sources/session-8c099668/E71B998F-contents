## Sheep

```{r}


sheeps |> 
  ggplot(mapping=aes(STP))+
  theme_classic()+
  geom_histogram(binwidth=0.5, 
                 fill="purple3", 
                 color="black", 
                 alpha=0.7)+
  labs(title = "Histogram of STP - SHEEP")


#create categories

sheeps<-sheeps %>% 
  mutate(levels = 
           case_when (
             STP <=5.1 ~ "LOW", 
             STP > 5.1 ~ "ADEQUATE"))

sheeps %>% 
  group_by(levels) %>% 
  count()


```

