pneu60_model <- coxme(Surv(PNEU60, P60) ~ quart_custom + SEX + (1|LOADfull) + (1|month) + (1|SRCE),  data = full)

summary(pneu60_model)
Anova(pneu60_model, type = "III")

test_ph <- cox.zph(pneu60_model)
print(test_ph)


interaction_means <- emmeans(pneu60_model, ~ quart_custom)
sd_contrasts <- pairs(interaction_means, reverse = FALSE) 
summary(sd_contrasts, type = "response", infer = c(TRUE, TRUE))
```

